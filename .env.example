# Meta / WhatsApp Cloud API credentials
WHATSAPP_TOKEN=EAAG...your-permanent-system-user-token
PHONE_NUMBER_ID=123456789012345
VERIFY_TOKEN=mmg-verify-2026
GRAPH_API_VERSION=v21.0

# Public https URL of THIS deployed app (no trailing slash).
# WhatsApp fetches the bundled PDFs from BASE_URL/pdfs/...
# e.g. https://mmg-whatsapp-bot.onrender.com
BASE_URL=

# Optional: published WhatsApp Flow ID for tick-box study options.
# Leave blank to use the numbered-reply fallback.
FLOW_ID=

# Lead storage
LEADS_CSV=./leads.csv
# Optional: Google Apps Script web-app URL to also append leads to a Google Sheet
SHEETS_WEBHOOK_URL=

PORT=3000
